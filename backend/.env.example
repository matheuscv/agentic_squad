# Chave secreta JWT (gerar com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-secret-key-here

# Algoritmo JWT
ALGORITHM=HS256

# Tempo de expiração do token (minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# URL do banco de dados
# SQLite local:    sqlite:///./contatos.db
# Supabase/Render: postgresql://postgres:[SENHA]@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./contatos.db

# Ambiente de execução: development | production
ENV=development

# Origens permitidas no CORS (separadas por vírgula)
# Ex. produção: https://seu-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:3002
