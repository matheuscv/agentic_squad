{
  "root": true,
  "extends": [
    "next/core-web-vitals",
    "plugin:security/recommended-legacy"
  ],
  "plugins": ["security"],
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "coverage/",
    "next-env.d.ts",
    "**/*.config.js",
    "jest.config.js"
  ],
  "rules": {
    "security/detect-object-injection": "warn"
  }
}
